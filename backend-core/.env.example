# ------- backend-core (.env) -------
# Copia este archivo a .env y complétalo. NO subas .env al repo (está en .gitignore).

# Proyecto Supabase (misma BD que /backend). Formato: https://<project-ref>.supabase.co
SUPABASE_URL=

# service_role key (Supabase Dashboard -> Project Settings -> API -> service_role).
# OBLIGATORIA en producción: el Core lee/escribe la cartera bajo RLS y el personal
# NO es usuario de Supabase Auth, así que la service_role hace bypass de RLS.
SUPABASE_SERVICE_KEY=

# anon key (fallback solo para arrancar en local; en prod se usa la service_role).
SUPABASE_KEY=

# Puerto. En Render se asigna por process.env.PORT automáticamente; local = 3001.
PORT=3001

# Origen permitido por CORS = URL del frontend-core (Vercel en prod; localhost en dev).
FRONTEND_CORE_URL=http://localhost:5174

# Secreto del JWT del personal (HS256). OBLIGATORIO en producción (el arranque falla si
# NODE_ENV=production y falta). Genera uno aleatorio, p.ej.:  openssl rand -hex 32
CORE_JWT_SECRET=

# Poner 'production' en Render para activar las validaciones estrictas de arriba.
NODE_ENV=development
