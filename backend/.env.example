# ------- backend / Homebanking (.env) -------
# Copia este archivo a .env y complétalo. NO subas .env al repo (está en .gitignore).

# Proyecto Supabase (misma BD que /backend-core). Formato: https://<project-ref>.supabase.co
SUPABASE_URL=

# anon key (Supabase Dashboard -> Project Settings -> API -> anon/public).
# El HB usa la anon key + el token del usuario para respetar RLS por cliente.
SUPABASE_KEY=

# Puerto. En Render se asigna por process.env.PORT automáticamente; local = 3000.
PORT=3000

# Origen permitido por CORS = URL del frontend Homebanking (Vercel en prod; localhost en dev).
FRONTEND_URL=http://localhost:5173

# Nota: el Homebanking NO usa un JWT_SECRET propio — la validación de tokens la hace
# Supabase (supabase.auth.getUser). No se requiere esa variable.
